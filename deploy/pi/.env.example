# Public host or IP of your Raspberry Pi (used by backend CORS + n8n URLs)
PI_HOST_OR_IP=192.168.1.50

# Docker Hub namespace and immutable image tags selected by the deployer
DOCKERHUB_NAMESPACE=mikedim95
BACKEND_TAG=latest
FRONTEND_TAG=latest

# MySQL credentials used by both MyTrader and n8n
MYSQL_DATABASE=mytrader
MYSQL_USER=mytrader
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me
DATABASE_URL=mysql://mytrader:change-me@mysql:3306/mytrader

# Optional upstream miner ingest target for the hosted Vercel dashboard.
# Leave blank to keep telemetry local to the Pi only.
MINER_INGEST_URL=
MINER_INGEST_TOKEN=
MINER_POLL_MS=60000
MINER_PUSH_SOURCE=pi
MINER_PUSH_TIMEOUT_MS=8000

# Optional timezone for n8n
GENERIC_TIMEZONE=Europe/Athens

# Strategy safety controls
STRATEGY_REQUIRE_APPROVAL_FOR_REAL_RUNS=true
STRATEGY_GLOBAL_KILL_SWITCH=false
# Give MySQL a short retry window before the backend falls back to offline mode.
STRATEGY_DB_INIT_RETRY_INTERVAL_MS=5000
STRATEGY_DB_INIT_MAX_RETRIES=12

# Wallet feature
JWT_SECRET=replace-with-a-long-random-secret
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JUPITER_API_URL=https://api.jup.ag/swap/v2
JUPITER_API_KEY=
AUTH_NONCE_TTL_MINUTES=10
WALLET_SESSION_TTL_HOURS=12

# Bot wallet must stay separate from Phantom.
BOT_SECRET_KEY_BASE58=

# Lightweight cache for BTC backtest preview modal
BACKTEST_PREVIEW_CACHE_TTL_MS=60000

# Historical candle pipeline and async strategy jobs
HISTORICAL_CANDLE_RETENTION_DAYS=540
HISTORICAL_CANDLE_REQUEST_DELAY_MS=250
HISTORICAL_CANDLE_MAX_RETRIES=3
HISTORICAL_CANDLE_FETCH_LIMIT=500
HISTORICAL_CANDLE_RETRY_BASE_DELAY_MS=750
STRATEGY_JOB_RETRY_BASE_DELAY_MS=30000
STRATEGY_JOB_MAX_ATTEMPTS=3

# Execution Safety guardrails
EXECUTION_GUARDRAIL_MIN_CONFIDENCE=0.55
EXECUTION_GUARDRAIL_MAX_POSITION_SIZE_PCT=25
EXECUTION_GUARDRAIL_MAX_BTC_EXPOSURE_PCT=55
EXECUTION_GUARDRAIL_COOLDOWN_MINUTES=60
EXECUTION_GUARDRAIL_MAX_DAILY_TURNOVER_PCT=75
EXECUTION_GUARDRAIL_NEWS_SHOCK_BEARISH_BIAS=-6
EXECUTION_GUARDRAIL_VOLATILITY_LOCKOUT=0.08
EXECUTION_GUARDRAIL_MILD_REDUCTION_FACTOR=0.5
