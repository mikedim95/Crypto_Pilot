PORT=3001
CORS_ORIGIN=http://localhost:8080

# Existing app storage still uses MySQL in this repo.
MYAPP_DB_HOST=localhost
MYAPP_DB_PORT=3306
MYAPP_DB_USER=mytrader
MYAPP_DB_PASSWORD=change-me
MYAPP_DB_NAME=mytrader

# Prisma wallet/auth storage for the new Wallet feature.
# Keep this pointed at the same MySQL instance for v1 to avoid a repo-wide database refactor.
DATABASE_URL=mysql://mytrader:change-me@localhost:3306/mytrader

JWT_SECRET=replace-with-a-long-random-secret
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JUPITER_API_URL=https://api.jup.ag/swap/v2
JUPITER_API_KEY=
AUTH_NONCE_TTL_MINUTES=10
WALLET_SESSION_TTL_HOURS=12

# Bot wallet stays separate from Phantom and should live on the Pi only.
BOT_SECRET_KEY_BASE58=
